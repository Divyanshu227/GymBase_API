PORT=5000
NODE_ENV=development
JWT_SECRET=your_strong_jwt_secret_here

MONGO_URI=mongodb+srv://<user>:<password>@clusterx.xxxxx.mongodb.net/gymbaseapi

# Frontend URL used in email links, Stripe redirects, and as a default CORS origin.
# Use the deployed frontend URL in production. Do not include a trailing slash.
FRONTEND_URL=https://gym-base-api.vercel.app

# Comma-separated browser origins allowed to call this API.
# These values must be set in the deployed backend environment too.
CORS_ORIGINS=http://localhost:5173,https://gym-base-api.vercel.app

# SMTP settings (Brevo or any SMTP provider)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_smtp_user@smtp-brevo.com
SMTP_PASS=your_brevo_smtp_password
email=your_verified_sender@example.com

# Stripe Settings
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
